class Solution:
    def minmax(self, nums):
        maximum = nums[0]
        minimum = nums[0]
        
        for i in range(1, len(nums)):
            if nums[i] > maximum:
                maximum = nums[i]
            
            if nums[i] < minimum:
                minimum = nums[i]
        
        return minimum, maximum

nums = list(map(int, input().split(",")))

obj = Solution()

mn, mx = obj.minmax(nums)
print("Minimum =", mn)
print("Maximum =", mx)
