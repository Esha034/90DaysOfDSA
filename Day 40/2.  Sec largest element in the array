nums=list(map(int,input().split()))

max_val,sec_max=float('-inf'),float('-inf')
for i in range(len(nums)):
    if nums[i]>max_val:
        sec_max=max_val
        max_val=nums[i]
    elif nums[i]>sec_max and nums[i]!=max_val:
        sec_max=nums[i]
        
if sec_max == float('-inf'):
    print(-1)
else:
    print(sec_max)
