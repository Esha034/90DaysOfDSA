#better

class Solution:
    def majorityElement(self, nums: List[int]) -> int:
        n=len(nums)
        mp={}
        for i in range(n):
            if nums[i] in mp:
                mp[nums[i]]+=1

            else:
                mp[nums[i]]=1

        for key in mp:
            if mp[key]>n//2:
                return key
