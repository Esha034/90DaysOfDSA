#optimal

class Solution:
    def maxProduct(self, nums: List[int]) -> int:
        n=len(nums)
        curr_max,curr_min,ans=nums[0],nums[0],nums[0]
        
        for i in range(1,n):
            # swap if negative
            if nums[i]<0:
                curr_max,curr_min=curr_min,curr_max
            curr_max=max(nums[i],curr_max*nums[i])
            curr_min=min(nums[i],curr_min*nums[i])
            ans=max(ans,curr_max)

        return ans








#better

class Solution:
    def maxProduct(self, nums: List[int]) -> int:
        n=len(nums)
        curr_max=nums[0]
        curr_min=nums[0]
        ans=nums[0]

        for i in range(1,n):

            temp=curr_max
            
            curr_max=max(nums[i],curr_max*nums[i],curr_min*nums[i])
            curr_min=min(nums[i],temp*nums[i],curr_min*nums[i])
            
            ans=max(ans,curr_max)
            
        return ans

#bruteforce

class Solution:
    def maxProduct(self, nums):
        max_res = float('-inf')
        n = len(nums)

        for i in range(n):
            res = 1

            for j in range(i, n):
                res *= nums[j]
                max_res = max(max_res, res)

        return max_res
