#bruteforce

class Solution:
    def findContentChildren(self, g: List[int], s: List[int]) -> int:
        used=[False]*len(s)
        count=0
        for child in g:
            for j in range(len(s)):
                if not used[j] and s[j]>=child:
                    used[j]=True
                    count+=1
                    break
        return count


#optimal 

class Solution:
    def findContentChildren(self, g: List[int], s: List[int]) -> int:
        g.sort()
        s.sort()
        i,j=0,0

        while i< len(g) and j<len(s):
            if s[j]>=g[i]:
                i+=1
                j+=1
            else:
                j+=1
        return i        
