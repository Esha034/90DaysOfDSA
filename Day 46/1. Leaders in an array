#bruteforce

def leaders(nums):
    n = len(nums)
    res = []

    for i in range(n):
        is_leader = True
        for j in range(i+1, n):
            if nums[j] >= nums[i]:
                is_leader = False
                break
        
        if is_leader:
            res.append(nums[i])

    return res

    
#Time complexity
  O(n²) ❌
