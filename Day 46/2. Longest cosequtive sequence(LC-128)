class Solution:
    def longestConsecutive(self, nums: List[int]) -> int:

        num_set=set(nums)
        max_len=0

        for num in num_set:
            if num-1 not in num_set:
                current=num
                count=1

                while current+1 in num_set:
                    current+=1
                    count+=1

                max_len=max(max_len,count)
        return max_len







#bruteforce


class Solution:
    def longestConsecutive(self, nums: List[int]) -> int:
        if not nums:
            return 0
        n=len(nums)
        count=1
        max_len=1
        nums=sorted(nums)
        for i in range(n-1):
            if nums[i+1]==nums[i]:
                continue
            elif nums[i+1]==nums[i]+1:
                count+=1
                max_len=max(count,max_len)
            else:
                count=1
        return max_len
