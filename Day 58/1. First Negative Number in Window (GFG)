#User function Template for python3

class Solution:
    def firstNegInt(self, nums, k):
        n=len(nums)
        from collections import deque
        q=deque()
        n=len(nums)
        res=[]
        l=0
        for r in range(n):
            if nums[r]<0:
                q.append(nums[r])
        
            if r-l+1==k:
                if q:
                    res.append(q[0])
                else:
                    res.append(0)
            
                if q and nums[l]==q[0]:
                    q.popleft()
                l+=1
        return res
 

