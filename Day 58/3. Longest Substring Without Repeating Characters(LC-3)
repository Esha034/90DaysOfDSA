#optimal 


class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        ans=0
        seen=set()
        l=0
        for r in range(len(s)):
            while s[r] in seen:
                seen.remove(s[l])
                l+=1
            
            seen.add(s[r])
            ans=max(ans,r-l+1)
        return ans


#bruteforce

class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        ans=0
        
        for i in range(len(s)):
            seen=set()
            for j in range(i,len(s)):
                if s[j] in seen:
                    break
                seen.add(s[j])
                ans=max(ans,j-i+1)
        return ans
