s = input()   # arr[]={1,2,3,4,5,6}

# Step 1: extract numbers part
nums_str = s[s.find("{")+1 : s.find("}")]

# Step 2: convert into list
nums = list(map(int, nums_str.split(",")))
x=int(input())
n=len(nums)
# Step 3: sum function
def findnum(arr,x):
    for i in range(n):
        if arr[i]==x:
            return i
    return -1


# Step 4: print result
print(f"Element x is present at index {findnum(nums,x)}")
