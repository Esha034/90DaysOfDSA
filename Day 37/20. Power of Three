#check if n is a power of 3 or not

n = int(input())

if n <= 0:
    print(False)
else:
    while n % 3 == 0:
        n //= 3
    print(n == 1)



#bruteforce approach
n=int(input())
if n<=0:
    print(False)
else:
    for i in range(n//2):
        if 3**i==n:
            print(True)
            break
    else:
        print(False)
