# Isomorphic Strings

s = input().strip()
t = input().strip()

if len(s) != len(t):
    print("False")
else:
    map1 = {}
    map2 = {}

    is_isomorphic = True

    for i in range(len(s)):
        c1 = s[i]
        c2 = t[i]

        if c1 in map1:
            if map1[c1] != c2:
                is_isomorphic = False
                break
        else:
            if c2 in map2:
                is_isomorphic = False
                break
            map1[c1] = c2
            map2[c2] = c1

    print("True" if is_isomorphic else "False")
