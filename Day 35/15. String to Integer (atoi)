# String to Integer (atoi)

s = input()
i = 0
n = len(s)

# Step 1: Ignore leading spaces
while i < n and s[i] == ' ':
    i += 1

# Step 2: Handle sign
sign = 1
if i < n and (s[i] == '+' or s[i] == '-'):
    if s[i] == '-':
        sign = -1
    i += 1

# Step 3: Convert digits
result = 0
while i < n and s[i].isdigit():
    result = result * 10 + int(s[i])
    i += 1

# Step 4: Apply sign
result *= sign

# Step 5: Clamp to 32-bit range
INT_MIN = -2**31
INT_MAX = 2**31 - 1

if result < INT_MIN:
    print(INT_MIN)
elif result > INT_MAX:
    print(INT_MAX)
else:
    print(result)
