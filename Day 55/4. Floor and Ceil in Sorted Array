class Solution:
    def getFloorAndCeil(self, nums, x):
        n=len(nums)

        low,high=0,n-1
        floor=-1
        while low<=high:

            mid=(low+high)//2

            if nums[mid]<=x:
                floor=nums[mid]
                low=mid+1
            else:
                high=mid-1
        low = 0
        high = n - 1
        ceil = -1

        while low <= high:
            
            mid = (low + high) // 2

            if nums[mid] >= x:
                ceil = nums[mid]
                high = mid-1
            else:
                low = mid + 1

        return[floor,ceil]
       
