class Solution:
    def longestSubarray(self, nums, k):

        pre_sum = 0
        max_len = 0
        mp = {0: -1}  

        for i in range(len(nums)):
            pre_sum += nums[i]

            if (pre_sum - k) in mp:
                max_len = max(max_len, i - mp[pre_sum - k])

            if pre_sum not in mp:
                mp[pre_sum] = i

        return max_len
