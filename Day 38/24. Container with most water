#optimal

height = list(map(int, input().split()))

left = 0
right = len(height) - 1
max_area = 0

while left < right:
    width = right - left
    h = min(height[left], height[right])
    max_area = max(max_area, width * h)
    
    if height[left] < height[right]:
        left += 1
    else:
        right -= 1

print(max_area)



#bruteforce
height=list(map(int,input().split()))

max=0
for i in range(len(height)):
    for j in range(i+1,len(height)):
        width=j-i
        h=min(height[i],height[j])
        current_max=width*h
        if current_max>max:
            max= current_max
print(max)
